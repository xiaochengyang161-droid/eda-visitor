{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "EDA Visitor",
  "version": "1.0.0",
  "identifier": "cn.dzsjxh.visitor",

  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },

  "app": {
    "windows": [
      {
        "title": "EDA Visitor",
        "width": 390,
        "height": 844,
        "resizable": false,
        "fullscreen": false,
        "maximized": false
      }
    ]
  }
}