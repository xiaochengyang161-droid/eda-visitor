{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "EDA Visitor",
  "version": "1.0.2",
  "identifier": "cn.dzsjxh.visitor",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "EDA Visitor",
